    on-surface-variant: rgba(219, 192, 190, 1);
    outline: rgba(163, 139, 137, 1);
    outline-variant: rgba(85, 66, 65, 1);
    shadow: rgba(0, 0, 0, 1);
    scrim: rgba(0, 0, 0, 1);
    inverse-surface: rgba(249, 220, 218, 1);
    inverse-on-surface: rgba(61, 44, 43, 1);
    inverse-primary: rgba(192, 0, 30, 1);
    surface-dim: rgba(30, 16, 15, 1);
    surface-bright: rgba(71, 53, 51, 0.1);
    surface-container-lowest: rgba(24, 11, 10, 1);
    surface-container-low: rgba(39, 24, 23, 1);
    surface-container: rgba(43, 28, 27, 1);
