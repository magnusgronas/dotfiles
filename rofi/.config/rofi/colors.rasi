    on-primary-container: rgba(255, 218, 215, 1);
    secondary: rgba(245, 185, 162, 1);
    secondary-fixed: rgba(255, 219, 206, 1);
    secondary-fixed-dim: rgba(245, 185, 162, 1);
    on-secondary: rgba(75, 38, 23, 1);
    on-secondary-fixed: rgba(50, 18, 5, 1);
    on-secondary-fixed-variant: rgba(102, 60, 43, 1);
    secondary-container: rgba(102, 60, 43, 1);
    on-secondary-container: rgba(255, 219, 206, 1);
    tertiary: rgba(252, 184, 132, 1);
    tertiary-fixed: rgba(255, 220, 195, 1);
    tertiary-fixed-dim: rgba(252, 184, 132, 1);
    on-tertiary: rgba(78, 38, 0, 1);
    on-tertiary-fixed: rgba(47, 21, 0, 1);
    on-tertiary-fixed-variant: rgba(105, 59, 18, 1);
